name: basic_cleaning
conda_env: conda.yml

entry_points:
  main:
    parameters:

      input_artifact:
        description: Name and version of the input artifact in W&B containing the raw dataset
        type: string

      output_artifact:
        description: Name of the artifact that will contain the cleaned dataset
        type: string

      output_type:
        description: Type assigned to the cleaned artifact in W&B
        type: string

      output_description:
        description: Description of the cleaned dataset artifact
        type: string

      min_price:
        description: Minimum allowed price for filtering outliers
        type: float

      max_price:
        description: Maximum allowed price for filtering outliers
        type: float


    command: >-
        python run.py  --input_artifact {input_artifact}  --output_artifact {output_artifact}  --output_type {output_type}  --output_description {output_description}  --min_price {min_price}  --max_price {max_price} 
